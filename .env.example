# ============================================================
# AI Classroom Co-Pilot — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Gemini API Key (required) ---
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- Whisper Model Size ---
# Options: tiny | base | small | medium | large-v3
# Recommended for CPU-only school computers: base
WHISPER_MODEL=base

# --- School / Institution Branding ---
SCHOOL_NAME=Haryana Govt. Smart Classroom

# --- App Settings ---
APP_DEBUG=false
MAX_QUIZ_QUESTIONS=15
DEFAULT_GRADE_LEVEL=6

# --- Audio Settings ---
TTS_LANGUAGE=hi
AUDIO_CLEANUP_HOURS=1
